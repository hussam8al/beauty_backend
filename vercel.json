{
    "version": 2,
    "builds": [
        {
            "src": "api/**/*.php",
            "use": "vercel-php@0.9.0"
        },
        {
            "src": "admin/**/*.php",
            "use": "vercel-php@0.9.0"
        },
        {
            "src": "includes/**/*.php",
            "use": "vercel-php@0.9.0"
        }
    ],
    "routes": [
        {
            "src": "/api/(.*)",
            "dest": "/api/$1"
        },
        {
            "src": "/admin/(.*)",
            "dest": "/admin/$1"
        },
        {
            "src": "/uploads/(.*)",
            "dest": "/uploads/$1"
        }
    ]
}
